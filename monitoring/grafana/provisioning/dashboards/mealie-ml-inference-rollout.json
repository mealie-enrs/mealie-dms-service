{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        { "expr": "mms_rollout_canary_weight_ratio", "legendFormat": "weight", "refId": "A" }
      ],
      "title": "Canary Weight",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 9, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(mms_serving_requests_total{job=\"mms-production\"}[5m]))",
          "legendFormat": "prod",
          "refId": "A"
        }
      ],
      "title": "Prod Request Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 9, "x": 15, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(mms_serving_requests_total{job=\"mms-canary\"}[5m]))",
          "legendFormat": "canary",
          "refId": "A"
        }
      ],
      "title": "Canary Request Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by(job, path) (rate(mms_serving_requests_total{job=~\"mms-production|mms-canary\"}[5m]))",
          "legendFormat": "{{job}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "Inference Throughput by Lane",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, job, path) (rate(mms_serving_request_latency_seconds_bucket{job=~\"mms-production|mms-canary\"}[5m])))",
          "legendFormat": "{{job}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "p95 Latency by Lane",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by(job) (rate(mms_serving_requests_total{job=~\"mms-production|mms-canary\",status=~\"5..\"}[5m])) / clamp_min(sum by(job) (rate(mms_serving_requests_total{job=~\"mms-production|mms-canary\"}[5m])), 1)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate by Lane",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "targets": [
        {
          "expr": "sum by(lane, status) (rate(mms_rollout_router_requests_total[5m]))",
          "legendFormat": "{{lane}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Router Decisions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": {
        "footer": { "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "mms_serving_active_model_info{job=~\"mms-production|mms-canary\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active Model by Lane",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "targets": [
        {
          "expr": "sum by(decision) (rate(mms_rollout_feedback_events_total[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "title": "Router Feedback Events",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mealie", "ml", "rollout"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Mealie ML - Inference & Rollout",
  "uid": "mealie-ml-rollout",
  "version": 1,
  "weekStart": ""
}
